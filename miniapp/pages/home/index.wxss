.home-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top, rgba(74, 225, 131, 0.18), transparent 28%),
    linear-gradient(180deg, #f4fbf6 0%, #edf6ff 100%);
  color: #0d2432;
  position: relative;
}

.floating-aura {
  position: absolute;
  border-radius: 50%;
  filter: blur(50rpx);
  opacity: 0.55;
  pointer-events: none;
}

.floating-aura-one {
  width: 360rpx;
  height: 360rpx;
  background: rgba(46, 204, 113, 0.18);
  top: 120rpx;
  left: -40rpx;
}

.floating-aura-two {
  width: 300rpx;
  height: 300rpx;
  background: rgba(113, 201, 255, 0.18);
  top: 520rpx;
  right: -60rpx;
}

.topbar {
  position: sticky;
  top: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 20rpx;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(24rpx);
  border-bottom-left-radius: 28rpx;
  border-bottom-right-radius: 28rpx;
  box-shadow: 0 12rpx 30rpx rgba(0, 109, 55, 0.08);
}

.brand {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.brand-icon,
.notify-button {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.brand-icon {
  background: linear-gradient(135deg, #26ba63, #69f19b);
  box-shadow: 0 10rpx 20rpx rgba(46, 204, 113, 0.2);
}

.brand-icon-image {
  width: 34rpx;
  height: 34rpx;
}

.brand-name {
  font-size: 36rpx;
  font-weight: 800;
  letter-spacing: -1rpx;
  color: #26a75d;
}

.notify-button {
  background: rgba(46, 204, 113, 0.12);
}

.notify-icon-image {
  width: 28rpx;
  height: 28rpx;
}

.home-scroll {
  height: calc(100vh - 110rpx);
}

.home-content {
  padding: 20rpx 32rpx 220rpx;
}

.hero-section {
  padding-top: 16rpx;
}

.ring-shell {
  width: 100%;
  height: 580rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ring-track,
.ring-progress {
  position: absolute;
  width: 430rpx;
  height: 430rpx;
  border-radius: 50%;
}

.ring-track {
  border: 28rpx solid rgba(209, 228, 251, 0.9);
  box-sizing: border-box;
}

.ring-progress {
  border: 28rpx solid transparent;
  border-top-color: #2ecc71;
  border-right-color: #2ecc71;
  box-sizing: border-box;
  transform: rotate(45deg);
  filter: drop-shadow(0 0 18rpx rgba(46, 204, 113, 0.35));
}

.ring-center {
  width: 300rpx;
  text-align: center;
  z-index: 1;
}

.ring-value-line {
  margin-top: 16rpx;
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 8rpx;
}

.ring-value {
  font-size: 92rpx;
  font-weight: 800;
  line-height: 1;
}

.ring-unit {
  font-size: 34rpx;
  color: #11884a;
  font-weight: 700;
}

.ring-feedback {
  margin-top: 18rpx;
  padding: 14rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(46, 204, 113, 0.08);
  border: 2rpx solid rgba(46, 204, 113, 0.08);
  font-size: 22rpx;
  line-height: 1.6;
  color: #0f6a39;
  font-weight: 700;
}

.ring-trend {
  margin-top: 18rpx;
  color: #6b7a70;
  font-size: 20rpx;
}

.agent-block {
  margin-top: -8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.agent-core-wrap {
  position: relative;
  width: 132rpx;
  height: 132rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.agent-core-glow {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: rgba(46, 204, 113, 0.22);
  filter: blur(24rpx);
}

.agent-core {
  position: relative;
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #0f9a50, #39ce76);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 6rpx solid rgba(255, 255, 255, 0.42);
  box-shadow: 0 18rpx 38rpx rgba(23, 117, 61, 0.18);
}

.agent-core-image {
  width: 54rpx;
  height: 54rpx;
}

.agent-badge {
  position: absolute;
  right: -18rpx;
  bottom: 6rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 2rpx solid rgba(46, 204, 113, 0.2);
  font-size: 18rpx;
  color: #169351;
  font-weight: 800;
}

.agent-dialog {
  width: 100%;
  padding: 28rpx;
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.76);
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 18rpx 44rpx rgba(0, 0, 0, 0.05);
  backdrop-filter: blur(28rpx);
  box-sizing: border-box;
}

.agent-dialog-bar {
  width: 100%;
  height: 6rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, transparent, rgba(46, 204, 113, 0.4), transparent);
  margin-bottom: 22rpx;
}

.agent-dialog-text {
  line-height: 1.8;
  font-size: 26rpx;
  font-weight: 600;
}

.agent-actions {
  margin-top: 24rpx;
  display: flex;
  gap: 16rpx;
}

.agent-primary,
.agent-secondary {
  flex: 1;
  border-radius: 999rpx;
  font-size: 24rpx;
  line-height: 1.4;
  padding: 18rpx 0;
}

.agent-primary {
  background: #20a95b;
  color: #fff;
}

.agent-secondary {
  background: #e7f0f9;
  color: #19303a;
}

.quick-grid {
  margin-top: 36rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.challenge-card {
  grid-column: span 2;
  position: relative;
  min-height: 270rpx;
  padding: 34rpx;
  border-radius: 38rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #0d8f4a, #26c56c);
  color: #fff;
  box-shadow: 0 18rpx 40rpx rgba(46, 204, 113, 0.22);
}

.challenge-badge {
  display: inline-block;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  font-size: 18rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.challenge-title {
  margin-top: 20rpx;
  font-size: 42rpx;
  font-weight: 800;
}

.challenge-desc {
  margin-top: 14rpx;
  width: 72%;
  line-height: 1.7;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.88);
}

.challenge-button {
  margin-top: 28rpx;
  width: 220rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #138949;
  font-size: 26rpx;
  font-weight: 700;
}

.challenge-mark {
  position: absolute;
  right: 26rpx;
  bottom: 18rpx;
  width: 150rpx;
  height: 150rpx;
  opacity: 0.1;
}

.quick-card {
  min-height: 190rpx;
  padding: 28rpx;
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.72);
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid rgba(255, 255, 255, 0.65);
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  box-sizing: border-box;
}

.quick-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  background: rgba(46, 204, 113, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
}

.quick-icon-image {
  width: 38rpx;
  height: 38rpx;
}

.quick-title {
  margin-top: 22rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.quick-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #6a776e;
  line-height: 1.5;
}

.section-head {
  margin-top: 40rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-title {
  font-size: 34rpx;
  font-weight: 800;
}

.section-link {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(46, 204, 113, 0.08);
  color: #179852;
  font-size: 22rpx;
  font-weight: 700;
}

.achievement-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 2rpx solid rgba(255, 255, 255, 0.7);
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.04);
}

.achievement-cover {
  width: 84rpx;
  height: 84rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #dbf6e4, #f2fbff);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.achievement-cover-image {
  width: 40rpx;
  height: 40rpx;
}

.achievement-main {
  flex: 1;
}

.achievement-title {
  font-size: 28rpx;
  font-weight: 700;
}

.achievement-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #6d7b72;
}

.achievement-side {
  text-align: right;
  flex-shrink: 0;
}

.achievement-carbon {
  color: #24af60;
  font-size: 28rpx;
  font-weight: 800;
}

.achievement-time {
  margin-top: 8rpx;
  color: #7e8c83;
  font-size: 20rpx;
}

.news-panel {
  margin-top: 36rpx;
  padding: 30rpx;
  border-radius: 38rpx;
  background: rgba(255, 255, 255, 0.55);
  border: 2rpx solid rgba(255, 255, 255, 0.7);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.5);
}

.news-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.news-live-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #1ca65a;
  box-shadow: 0 0 16rpx rgba(28, 166, 90, 0.45);
}

.news-live-label {
  font-size: 18rpx;
  font-weight: 800;
  letter-spacing: 3rpx;
  color: #7b8a7f;
}

.news-card {
  margin-top: 22rpx;
  padding: 28rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.84);
}

.news-quote {
  font-size: 26rpx;
  line-height: 1.8;
  color: #1d2d35;
}

.news-author-row {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.news-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #16a256, #79e39e);
  display: flex;
  align-items: center;
  justify-content: center;
}

.news-avatar-image {
  width: 28rpx;
  height: 28rpx;
}

.news-author {
  font-size: 24rpx;
  font-weight: 700;
}

.news-time {
  margin-top: 6rpx;
  color: #809087;
  font-size: 20rpx;
}

.footer-note {
  margin-top: 48rpx;
  padding-bottom: 20rpx;
  text-align: center;
  color: #95a097;
  font-size: 20rpx;
}

.footer-sub {
  margin-top: 8rpx;
}

.voice-fab {
  position: fixed;
  right: 28rpx;
  bottom: 180rpx;
  width: 116rpx;
  height: 116rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #169b52, #39ce76);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 20rpx 34rpx rgba(46, 204, 113, 0.28);
  z-index: 25;
}

.voice-fab-image {
  width: 46rpx;
  height: 46rpx;
}

.bottom-nav {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 24;
  padding: 18rpx 10rpx 34rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(36rpx);
  border-top-left-radius: 36rpx;
  border-top-right-radius: 36rpx;
  box-shadow: 0 -12rpx 40rpx rgba(0, 0, 0, 0.05);
}

.nav-item {
  width: 100rpx;
  padding: 12rpx 6rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #8d9891;
}

.nav-item-active {
  background: rgba(46, 204, 113, 0.12);
  color: #1aa15a;
}

.nav-icon {
  width: 30rpx;
  height: 30rpx;
  opacity: 0.42;
}

.nav-item-active .nav-icon {
  opacity: 1;
}

.nav-label {
  margin-top: 8rpx;
  font-size: 18rpx;
  font-weight: 700;
}
