.legal-page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #f7fbf8 0%, #eef4ff 100%);
}

.legal-header {
  margin-bottom: 24rpx;
}

.legal-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #112430;
}

.legal-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6f7d75;
}

.legal-card {
  margin-bottom: 20rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 40rpx rgba(24, 45, 67, 0.06);
}

.legal-card-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #122630;
}

.legal-item {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #56666f;
}
