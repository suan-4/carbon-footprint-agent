.profile-shell {
  background:
    radial-gradient(circle at top, rgba(74, 225, 131, 0.14), transparent 24%),
    linear-gradient(180deg, #f7fbf8 0%, #eef4ff 100%);
}

.profile-hero {
  display: grid;
  grid-template-columns: 1.8fr 1fr;
  gap: 18rpx;
}

.profile-user-card {
  padding: 30rpx;
  border-radius: 34rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.profile-avatar-wrap {
  position: relative;
  width: 112rpx;
  height: 112rpx;
  flex-shrink: 0;
}

.profile-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #eff8f1, #e5f1ff);
}

.profile-verified {
  position: absolute;
  right: -4rpx;
  bottom: -2rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #2ecc71;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 20rpx rgba(46, 204, 113, 0.18);
}

.profile-verified-icon {
  width: 24rpx;
  height: 24rpx;
}

.profile-user-main {
  flex: 1;
}

.profile-user-name {
  font-size: 36rpx;
  font-weight: 800;
  color: #102430;
}

.profile-user-level {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #6e7a73;
}

.profile-verified-pill {
  margin-top: 14rpx;
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(46, 204, 113, 0.12);
  color: #159652;
  font-size: 18rpx;
  font-weight: 800;
}

.profile-pill-icon {
  width: 18rpx;
  height: 18rpx;
}

.profile-carbon-card {
  border-radius: 34rpx;
  padding: 30rpx 20rpx;
  background: rgba(209, 228, 251, 0.68);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
}

.profile-carbon-value {
  font-size: 54rpx;
  line-height: 1;
  font-weight: 800;
  color: #149451;
}

.profile-carbon-label {
  margin-top: 12rpx;
  font-size: 18rpx;
  letter-spacing: 2rpx;
  color: #6e7c73;
  font-weight: 800;
}

.profile-section-label {
  margin: 34rpx 8rpx 14rpx;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: #7c8780;
  font-weight: 800;
}

.profile-session-card {
  margin-top: 20rpx;
  padding: 26rpx 28rpx;
  border-radius: 34rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.profile-session-copy {
  flex: 1;
}

.profile-session-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #122630;
}

.profile-session-desc {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #7b8780;
}

.profile-session-button {
  margin: 0;
  min-width: 184rpx;
  padding: 0 28rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 999rpx;
  background: #2ecc71;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
}

.profile-panel {
  border-radius: 34rpx;
  overflow: hidden;
}

.profile-row {
  padding: 26rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.profile-row-divider {
  border-bottom: 2rpx solid rgba(187, 203, 187, 0.14);
}

.profile-row-left {
  display: flex;
  align-items: center;
  gap: 18rpx;
  flex: 1;
}

.profile-row-icon {
  width: 84rpx;
  height: 84rpx;
  border-radius: 24rpx;
  background: rgba(46, 204, 113, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.profile-row-icon-neutral {
  background: rgba(9, 29, 46, 0.05);
}

.profile-row-icon-image {
  width: 38rpx;
  height: 38rpx;
}

.profile-row-copy {
  flex: 1;
}

.profile-row-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #122630;
}

.profile-row-desc {
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.5;
  color: #7b8780;
}

.profile-toggle {
  width: 88rpx;
  height: 48rpx;
  border-radius: 999rpx;
  background: rgba(187, 203, 187, 0.4);
  position: relative;
  flex-shrink: 0;
}

.profile-toggle-on {
  background: #7bf8a1;
}

.profile-toggle-dot {
  position: absolute;
  top: 6rpx;
  left: 6rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.1);
}

.profile-toggle-dot-on {
  left: 46rpx;
}

.profile-chevron {
  width: 22rpx;
  height: 22rpx;
  flex-shrink: 0;
}

.profile-footer {
  margin-top: 40rpx;
  padding-bottom: 16rpx;
  text-align: center;
  color: #98a49b;
  font-size: 20rpx;
}

.profile-footer-links {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 10rpx;
}
