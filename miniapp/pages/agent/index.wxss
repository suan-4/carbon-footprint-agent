.agent-shell {
  background:
    radial-gradient(circle at top, rgba(74, 225, 131, 0.14), transparent 24%),
    linear-gradient(180deg, #f7fbf8 0%, #eef4ff 100%);
}

.agent-topbar-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  width: 100%;
}

.agent-back-button {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #16a256, #39ce76);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  flex-shrink: 0;
  box-shadow: 0 8rpx 18rpx rgba(46, 204, 113, 0.18);
}

.agent-back-button::after,
.chat-suggestion-chip::after,
.agent-send-button::after {
  border: none;
}

.agent-back-icon {
  width: 24rpx;
  height: 24rpx;
  transform: rotate(180deg);
  opacity: 1;
  filter: brightness(0) invert(1);
}

.agent-topbar-caption {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #56635d;
}

.agent-brand-copy {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.agent-shell .shell-brand-title {
  color: #138548;
}

.agent-shell .shell-brand {
  flex: 1;
  justify-content: space-between;
  min-width: 0;
}

.agent-shell .shell-brand-icon {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.agent-scroll {
  height: calc(100vh - 116rpx);
}

.agent-content {
  padding-bottom: 220rpx;
}

.agent-hero {
  margin-bottom: 28rpx;
}

.agent-hero-badge {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(46, 204, 113, 0.12);
  color: #169452;
  font-size: 18rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.agent-hero-title {
  margin-top: 18rpx;
  font-size: 36rpx;
  line-height: 1.4;
  font-weight: 800;
  color: #102530;
}

.agent-hero-desc {
  margin-top: 12rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #728077;
}

.chat-row {
  margin-bottom: 28rpx;
}

.chat-row-user {
  display: flex;
  justify-content: flex-end;
}

.chat-row-assistant {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.chat-assistant-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.chat-assistant-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #12a154, #43d47d);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 24rpx rgba(46, 204, 113, 0.18);
}

.chat-assistant-avatar-image {
  width: 28rpx;
  height: 28rpx;
}

.chat-assistant-name {
  font-size: 22rpx;
  font-weight: 800;
  color: #139251;
}

.chat-card {
  max-width: 100%;
  border-radius: 30rpx;
  padding: 24rpx 26rpx;
  box-sizing: border-box;
}

.chat-card-assistant {
  width: 100%;
  background: rgba(255, 255, 255, 0.76);
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: 0 16rpx 36rpx rgba(0, 0, 0, 0.04);
}

.chat-card-user {
  max-width: 84%;
  background: linear-gradient(135deg, #169b52, #39ce76);
  color: #ffffff;
  box-shadow: 0 18rpx 34rpx rgba(46, 204, 113, 0.2);
}

.chat-card-loading {
  opacity: 0.92;
}

.chat-text {
  font-size: 26rpx;
  line-height: 1.8;
  color: inherit;
  white-space: pre-wrap;
}

.chat-card-assistant .chat-text {
  color: #112530;
}

.chat-loading-dots {
  margin-top: 18rpx;
  display: flex;
  gap: 10rpx;
}

.chat-loading-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #2ecc71;
  animation: loadingPulse 1.1s ease-in-out infinite;
}

.chat-loading-dot:nth-child(2) {
  animation-delay: 0.15s;
}

.chat-loading-dot:nth-child(3) {
  animation-delay: 0.3s;
}

.chat-suggestion-list {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.chat-suggestion-chip {
  margin: 0;
  padding: 14rpx 20rpx;
  min-height: 0;
  border-radius: 999rpx;
  background: rgba(46, 204, 113, 0.1);
  color: #148f50;
  font-size: 22rpx;
  line-height: 1.4;
  font-weight: 700;
  border: 2rpx solid rgba(46, 204, 113, 0.1);
}

.agent-composer-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 24;
  padding: 16rpx 20rpx 20rpx;
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(20rpx);
  box-shadow: 0 -6rpx 18rpx rgba(0, 0, 0, 0.03);
}

.agent-composer-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.agent-composer-shell {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-height: 66rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #f5f5f3;
  border: 2rpx solid rgba(16, 37, 48, 0.05);
}

.agent-composer-mic {
  width: 26rpx;
  height: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.agent-composer-mic-icon {
  width: 20rpx;
  height: 20rpx;
  opacity: 0.72;
}

.agent-input {
  flex: 1;
  min-width: 0;
  height: 66rpx;
  padding: 0;
  background: transparent;
  border: none;
  box-sizing: border-box;
  font-size: 24rpx;
  line-height: 66rpx;
  color: #102530;
}

.agent-send-button {
  width: 54rpx;
  height: 54rpx;
  min-width: 54rpx;
  min-height: 54rpx;
  padding: 0;
  border-radius: 50%;
  background: linear-gradient(135deg, #0c8b44, #0a7f3e);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 6rpx 14rpx rgba(12, 139, 68, 0.16),
    0 0 0 6rpx rgba(12, 139, 68, 0.05);
  flex-shrink: 0;
}

.agent-send-button-disabled {
  opacity: 0.6;
}

.agent-send-icon {
  width: 20rpx;
  height: 20rpx;
}

@keyframes loadingPulse {
  0%, 100% {
    opacity: 0.32;
    transform: scale(0.82);
  }
  50% {
    opacity: 1;
    transform: scale(1);
  }
}
