.mall-shell {
  background:
    radial-gradient(circle at top, rgba(74, 225, 131, 0.14), transparent 24%),
    linear-gradient(180deg, #f7fbf8 0%, #eef4ff 100%);
}

.mall-content {
  padding-bottom: 220rpx;
}

.mall-toast-layer {
  position: fixed;
  inset: 0;
  z-index: 45;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  box-sizing: border-box;
}

.mall-toast-card {
  position: relative;
  overflow: hidden;
  width: 100%;
  max-width: 560rpx;
  border-radius: 34rpx;
  background:
    radial-gradient(circle at top right, rgba(130, 255, 173, 0.42), transparent 28%),
    linear-gradient(135deg, rgba(15, 155, 81, 0.96), rgba(56, 207, 116, 0.94));
  box-shadow: 0 26rpx 50rpx rgba(21, 117, 61, 0.28);
  animation: mallToastIn 0.34s cubic-bezier(0.22, 1, 0.36, 1);
}

.mall-toast-glow {
  position: absolute;
  right: -34rpx;
  top: -42rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  filter: blur(10rpx);
}

.mall-toast-main {
  position: relative;
  padding: 34rpx 30rpx 30rpx;
  color: #ffffff;
  text-align: center;
}

.mall-toast-badge {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 18rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.mall-toast-title {
  margin-top: 18rpx;
  font-size: 38rpx;
  line-height: 1.2;
  font-weight: 800;
}

.mall-toast-order {
  margin-top: 16rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.92);
}

.mall-toast-meta {
  margin-top: 22rpx;
  display: flex;
  justify-content: center;
}

.mall-toast-chip {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 20rpx;
  font-weight: 700;
}

.mall-balance-pill {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(46, 204, 113, 0.12);
  color: #159752;
  font-weight: 800;
}

.mall-balance-pill-icon {
  width: 24rpx;
  height: 24rpx;
}

.mall-balance-pill-value {
  font-size: 24rpx;
  line-height: 1;
}

.mall-hero {
  position: relative;
  overflow: hidden;
  min-height: 360rpx;
  background: linear-gradient(135deg, #129a50, #39ce76);
  color: #ffffff;
  box-shadow: 0 24rpx 48rpx rgba(31, 166, 89, 0.22);
}

.mall-hero::after {
  content: '';
  position: absolute;
  right: -90rpx;
  top: -80rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
}

.mall-hero-badge {
  position: relative;
  display: inline-block;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 18rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.mall-hero-title {
  position: relative;
  margin-top: 26rpx;
  max-width: 420rpx;
  font-size: 46rpx;
  line-height: 1.18;
  font-weight: 800;
}

.mall-hero-desc {
  position: relative;
  margin-top: 16rpx;
  max-width: 430rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.86);
}

.mall-hero-meta {
  position: relative;
  margin-top: 24rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.mall-hero-meta-pill {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  font-size: 20rpx;
  font-weight: 700;
}

.mall-hero-meta-pill-ghost {
  background: rgba(6, 72, 34, 0.18);
}

.mall-hero-meta-icon {
  width: 20rpx;
  height: 20rpx;
}

.mall-hero-bottom {
  position: relative;
  margin-top: 30rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
}

.mall-hero-price {
  font-size: 56rpx;
  line-height: 1;
  font-weight: 800;
}

.mall-hero-price-unit {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.82);
}

.mall-hero-button {
  margin: 0;
  padding: 0 34rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #159752;
  font-size: 26rpx;
  font-weight: 800;
  box-shadow: 0 12rpx 24rpx rgba(0, 0, 0, 0.08);
}

.mall-hero-button::after {
  border: none;
}

.mall-hero-button-disabled {
  background: rgba(255, 255, 255, 0.38);
  color: rgba(255, 255, 255, 0.92);
  box-shadow: none;
}

.mall-hero-orb {
  position: absolute;
  right: 28rpx;
  top: 38rpx;
  width: 140rpx;
  height: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mall-hero-orb-glow {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  filter: blur(14rpx);
}

.mall-hero-orb-main {
  position: relative;
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  border: 6rpx solid rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.mall-hero-orb-image {
  width: 54rpx;
  height: 54rpx;
}

.mall-stats {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.mall-stat-card {
  padding: 28rpx 24rpx;
  border-radius: 30rpx;
}

.mall-stat-label {
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: #77857c;
  font-weight: 800;
}

.mall-stat-value {
  margin-top: 18rpx;
  font-size: 52rpx;
  line-height: 1;
  font-weight: 800;
  color: #119652;
}

.mall-stat-desc {
  margin-top: 14rpx;
  font-size: 20rpx;
  line-height: 1.6;
  color: #708077;
}

.mall-product-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.mall-product-card {
  border-radius: 30rpx;
  padding: 24rpx;
  display: flex;
  gap: 20rpx;
}

.mall-product-icon-wrap {
  width: 108rpx;
  height: 108rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.mall-category-physical {
  background: rgba(46, 204, 113, 0.14);
}

.mall-category-virtual {
  background: rgba(117, 203, 255, 0.18);
}

.mall-category-badge {
  background: rgba(255, 213, 79, 0.22);
}

.mall-product-icon {
  width: 48rpx;
  height: 48rpx;
}

.mall-product-main {
  flex: 1;
  min-width: 0;
}

.mall-product-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.mall-product-name {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 800;
  color: #102530;
}

.mall-product-pill {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 800;
}

.mall-pill-physical {
  background: rgba(46, 204, 113, 0.12);
  color: #159752;
}

.mall-pill-virtual {
  background: rgba(117, 203, 255, 0.18);
  color: #2f7bb8;
}

.mall-pill-badge {
  background: rgba(255, 213, 79, 0.22);
  color: #9a6a00;
}

.mall-product-desc {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.65;
  color: #6f7d75;
}

.mall-product-meta {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.mall-product-stock,
.mall-product-hint {
  font-size: 20rpx;
  color: #7d8a83;
}

.mall-product-stock {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(9, 29, 46, 0.05);
}

.mall-product-bottom {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.mall-product-price {
  font-size: 28rpx;
  font-weight: 800;
  color: #119652;
}

.mall-product-button {
  margin: 0;
  min-width: 156rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.mall-product-button::after {
  border: none;
}

.mall-product-button-active {
  background: #22ab5d;
  color: #ffffff;
}

.mall-product-button-disabled {
  background: rgba(187, 203, 187, 0.34);
  color: #6e7c73;
}

.mall-guide {
  border-radius: 34rpx;
  overflow: hidden;
}

.mall-guide-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 28rpx 0;
}

.mall-guide-row-divider {
  border-bottom: 2rpx solid rgba(187, 203, 187, 0.14);
}

.mall-guide-index {
  width: 64rpx;
  height: 64rpx;
  border-radius: 22rpx;
  background: rgba(46, 204, 113, 0.12);
  color: #159752;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.mall-guide-copy {
  flex: 1;
}

.mall-guide-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #102530;
}

.mall-guide-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #708077;
}

.mall-guide-chevron {
  width: 22rpx;
  height: 22rpx;
  flex-shrink: 0;
}

.mall-footer {
  margin-top: 40rpx;
  padding-bottom: 16rpx;
  text-align: center;
  color: #98a49b;
  font-size: 20rpx;
}

.mall-footer-sub {
  margin-top: 8rpx;
}

@keyframes mallToastIn {
  0% {
    opacity: 0;
    transform: translateY(-24rpx) scale(0.96);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
