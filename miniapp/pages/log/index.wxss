.log-shell {
  background:
    radial-gradient(circle at top, rgba(74, 225, 131, 0.14), transparent 24%),
    linear-gradient(180deg, #f7fbf8 0%, #eef4ff 100%);
}

.log-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0 18rpx;
  text-align: center;
}

.log-hero-title {
  font-size: 42rpx;
  line-height: 1.35;
  font-weight: 800;
  color: #122733;
}

.log-hero-subtitle {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #6d7a73;
}

.log-orb {
  margin-top: 36rpx;
  animation: floatingUpDown 3s ease-in-out infinite;
}

.reward-toast-layer {
  position: fixed;
  inset: 0;
  z-index: 40;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  box-sizing: border-box;
}

.reward-toast-card {
  position: relative;
  overflow: hidden;
  width: 100%;
  max-width: 560rpx;
  border-radius: 34rpx;
  background:
    radial-gradient(circle at top right, rgba(130, 255, 173, 0.42), transparent 28%),
    linear-gradient(135deg, rgba(15, 155, 81, 0.96), rgba(56, 207, 116, 0.94));
  box-shadow: 0 26rpx 50rpx rgba(21, 117, 61, 0.28);
  animation: rewardToastIn 0.38s cubic-bezier(0.22, 1, 0.36, 1);
}

.reward-toast-glow {
  position: absolute;
  right: -30rpx;
  top: -40rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  filter: blur(10rpx);
}

.reward-toast-main {
  position: relative;
  padding: 34rpx 30rpx 30rpx;
  color: #ffffff;
}

.reward-toast-title {
  text-align: center;
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.reward-toast-metrics {
  margin-top: 24rpx;
  display: flex;
  gap: 16rpx;
}

.reward-metric-chip {
  flex: 1;
  min-height: 98rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.14);
  backdrop-filter: blur(16rpx);
}

.reward-metric-points {
  border: 2rpx solid rgba(255, 255, 255, 0.14);
}

.reward-metric-carbon {
  border: 2rpx solid rgba(194, 255, 209, 0.24);
}

.reward-metric-label {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.76);
}

.reward-metric-value {
  display: block;
  margin-top: 10rpx;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 800;
}

.voice-record-wrap {
  position: relative;
  width: 260rpx;
  height: 260rpx;
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.voice-ring {
  position: absolute;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(46, 204, 113, 0.12);
  animation: voicePulse 2.2s ease-in-out infinite;
}

.voice-record-button {
  position: relative;
  width: 170rpx;
  height: 170rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1ba95b, #44d47f);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 54rpx;
  font-weight: 800;
  box-shadow: 0 20rpx 38rpx rgba(46, 204, 113, 0.22);
  border: 8rpx solid rgba(255, 255, 255, 0.38);
}

.voice-record-icon {
  width: 66rpx;
  height: 66rpx;
}

.text-entry-card {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.text-entry-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 26rpx;
  background: #2ecc71;
  border: 2rpx solid rgba(17, 138, 72, 0.16);
  box-shadow: 0 14rpx 28rpx rgba(46, 204, 113, 0.2);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.text-entry-icon-image {
  width: 42rpx;
  height: 42rpx;
}

.text-entry-main {
  flex: 1;
}

.text-entry-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #112430;
}

.text-entry-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #728077;
}

.behavior-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.behavior-card {
  padding: 24rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: 0 14rpx 32rpx rgba(0, 0, 0, 0.04);
}

.behavior-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.behavior-icon {
  width: 74rpx;
  height: 74rpx;
  border-radius: 24rpx;
  background: rgba(46, 204, 113, 0.12);
  color: #199957;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 800;
}

.behavior-icon-image {
  width: 40rpx;
  height: 40rpx;
}

.behavior-carbon {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(123, 248, 161, 0.28);
  color: #0f8c4d;
  font-size: 18rpx;
  font-weight: 800;
}

.behavior-name {
  margin-top: 22rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #122530;
}

.behavior-desc {
  margin-top: 10rpx;
  font-size: 20rpx;
  line-height: 1.5;
  color: #7b8780;
}

.log-footer {
  margin-top: 42rpx;
  padding-bottom: 16rpx;
  text-align: center;
  color: #97a39a;
  font-size: 20rpx;
}

.log-footer-links {
  margin-top: 12rpx;
  display: flex;
  justify-content: center;
  gap: 26rpx;
}

@keyframes voicePulse {
  0% {
    transform: scale(0.88);
    opacity: 0.65;
  }
  70% {
    transform: scale(1);
    opacity: 0.14;
  }
  100% {
    transform: scale(0.88);
    opacity: 0.65;
  }
}

@keyframes rewardToastIn {
  0% {
    opacity: 0;
    transform: translateY(-24rpx) scale(0.96);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
