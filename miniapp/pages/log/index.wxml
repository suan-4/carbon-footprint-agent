<view class="app-shell log-shell">
  <view class="shell-aura shell-aura-left"></view>
  <view class="shell-aura shell-aura-right"></view>

  <view class="shell-topbar">
    <view class="shell-brand">
      <view class="shell-brand-icon">
        <image class="shell-brand-icon-image" src="/assets/icons/leaf.svg" mode="aspectFit"></image>
      </view>
      <view class="shell-brand-title">碳迹同行</view>
    </view>
  </view>

  <view wx:if="{{rewardToast.visible}}" class="reward-toast-layer" catchtap="hideRewardToast">
    <view class="reward-toast-card">
      <view class="reward-toast-glow"></view>
      <view class="reward-toast-main">
        <view class="reward-toast-title">{{rewardToast.title}}</view>
        <view class="reward-toast-metrics">
          <view class="reward-metric-chip reward-metric-points">
            <text class="reward-metric-label">积分</text>
            <text class="reward-metric-value">+{{rewardToast.points}}</text>
          </view>
          <view class="reward-metric-chip reward-metric-carbon">
            <text class="reward-metric-label">减碳</text>
            <text class="reward-metric-value">{{rewardToast.carbonText}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <scroll-view scroll-y class="shell-scroll">
    <view class="shell-content">
      <view class="log-hero">
        <view class="log-hero-title">告诉小碳你今天的减碳行为</view>
        <view class="log-hero-subtitle">例如：“今天在食堂使用了自带餐具”</view>

        <view class="assistant-orb-wrap log-orb">
          <view class="assistant-orb-glow"></view>
          <view class="assistant-orb">
            <image class="assistant-orb-image" src="/assets/icons/robot.svg" mode="aspectFit"></image>
          </view>
          <view class="assistant-orb-badge">小碳 AI</view>
        </view>

        <view class="voice-record-wrap">
          <view class="voice-ring"></view>
          <button class="voice-record-button" bindtap="openVoiceRecord">
            <image class="voice-record-icon" src="/assets/icons/mic.svg" mode="aspectFit"></image>
          </button>
        </view>

        <view class="capsule-pill">
          <view class="pill-icon">
            <image class="pill-icon-image" src="/assets/icons/verified.svg" mode="aspectFit"></image>
          </view>
          <view>隐私声明：语音仅在本地处理，不上传云端</view>
        </view>
      </view>

      <view class="glass-surface shell-card text-entry-card" bindtap="openTextQa">
        <view class="text-entry-icon">
          <image class="text-entry-icon-image" src="/assets/icons/robot.svg" mode="aspectFit"></image>
        </view>
        <view class="text-entry-main">
          <view class="text-entry-title">小碳问答</view>
          <view class="text-entry-desc">AI 助手陪你聊减碳心得</view>
        </view>
      </view>

      <view class="mini-section-head">
        <view class="mini-section-title">快捷记录</view>
        <view class="mini-section-link">推荐行为</view>
      </view>

      <view class="behavior-grid">
        <block wx:for="{{behaviorTypes}}" wx:key="code">
          <view class="behavior-card" data-name="{{item.name}}" data-code="{{item.code}}" bindtap="selectBehavior">
            <view class="behavior-card-top">
              <view class="behavior-icon">
                <image class="behavior-icon-image" src="{{item.icon}}" mode="aspectFit"></image>
              </view>
              <view class="behavior-carbon">{{item.carbon}}</view>
            </view>
            <view class="behavior-name">{{item.name}}</view>
            <view class="behavior-desc">{{item.desc}}</view>
          </view>
        </block>
      </view>

      <view class="log-footer">
        <view>© 2026 碳迹同行 Initiative</view>
        <view class="log-footer-links">
          <text>隐私政策</text>
          <text>服务协议</text>
          <text>关于我们</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <button class="shell-fab" bindtap="openTextQa">
    <image class="shell-fab-image" src="/assets/icons/robot.svg" mode="aspectFit"></image>
  </button>

  <view class="shell-bottom-nav">
    <block wx:for="{{tabs}}" wx:key="key">
      <view class="shell-nav-item {{item.key === 'log' ? 'shell-nav-item-active' : ''}}" data-path="{{item.path}}" bindtap="goToPage">
        <image class="shell-nav-icon" src="{{item.icon}}" mode="aspectFit"></image>
        <view class="shell-nav-label">{{item.label}}</view>
      </view>
    </block>
  </view>
</view>
