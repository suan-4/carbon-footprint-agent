.settings-page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #f7fbf8 0%, #eef4ff 100%);
}

.settings-card {
  margin-bottom: 24rpx;
  padding: 30rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 18rpx 40rpx rgba(24, 45, 67, 0.06);
}

.settings-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #112430;
}

.settings-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6f7d75;
}

.settings-section-title,
.settings-label {
  font-size: 24rpx;
  font-weight: 800;
  color: #22323d;
}

.settings-current + .settings-current {
  margin-top: 20rpx;
}

.settings-current {
  margin-top: 24rpx;
}

.settings-value {
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 800;
  color: #149451;
}

.settings-url {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #6f7d75;
  word-break: break-all;
}

.settings-option {
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(20, 148, 81, 0.08);
  background: #f9fcfa;
}

.settings-option-active {
  border-color: rgba(20, 148, 81, 0.36);
  background: rgba(46, 204, 113, 0.08);
}

.settings-option-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #122630;
}

.settings-option-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #718078;
}

.settings-input-block {
  margin-top: 24rpx;
}

.settings-input {
  margin-top: 14rpx;
  padding: 0 22rpx;
  height: 88rpx;
  border-radius: 22rpx;
  background: #f7faf8;
  border: 2rpx solid rgba(20, 148, 81, 0.08);
  font-size: 24rpx;
  color: #122630;
}

.settings-save,
.settings-reset {
  margin-top: 24rpx;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.settings-save {
  background: #2ecc71;
  color: #ffffff;
}

.settings-save::after,
.settings-reset::after {
  border: none;
}

.settings-reset {
  background: rgba(9, 29, 46, 0.06);
  color: #22323d;
}
